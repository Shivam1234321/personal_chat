rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function convoMember(data) {
      return signedIn() && (request.auth.uid in data.members);
    }

    match /users/{uid} {
      allow create: if isMe(uid);
      allow read, update: if isMe(uid);
      allow delete: if false;
    }

    // Email -> uid lookup. We allow "get" but not "list" so nobody can dump all emails.
    match /userEmails/{emailLower} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == emailLower;
      allow update, delete: if false;
    }

    match /conversations/{conversationId} {
      allow get, list: if convoMember(resource.data);

      allow create: if signedIn()
        && request.resource.data.members.size() == 2
        && (request.auth.uid in request.resource.data.members);

      allow update: if convoMember(resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if convoMember(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
        allow create: if signedIn()
          && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.members)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000;
        allow update, delete: if false;
      }
    }
  }
}

