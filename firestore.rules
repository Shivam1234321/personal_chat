rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function convoMember(data) {
      return signedIn() && (request.auth.uid in data.members);
    }

    match /users/{uid} {
      allow create: if isMe(uid);
      allow read, update: if isMe(uid);
      allow delete: if false;
    }

    // Email -> uid lookup. We allow "get" but not "list" so nobody can dump all emails.
    match /userEmails/{emailLower} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == emailLower;
      allow update, delete: if false;
    }

    match /conversations/{conversationId} {
      allow get, list: if convoMember(resource.data);

      allow create: if signedIn()
        && request.resource.data.members.size() == 2
        && (request.auth.uid in request.resource.data.members);

      allow update: if convoMember(resource.data);
      allow delete: if false;

      match /typing/{uid} {
        function convoDoc() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
        }

        function isMember() {
          return signedIn() && request.auth.uid in convoDoc().members;
        }

        function validTypingDoc() {
          return request.resource.data.keys().hasAll(['isTyping', 'lastUpdated'])
            && request.resource.data.keys().hasOnly(['isTyping', 'lastUpdated'])
            && request.resource.data.isTyping is bool
            && (request.resource.data.lastUpdated is timestamp || request.resource.data.lastUpdated == null);
        }

        allow get, list: if isMember();

        allow create, update: if signedIn()
          && request.auth.uid == uid
          && isMember()
          && validTypingDoc();

        allow delete: if false;
      }

      match /messages/{messageId} {
        allow get, list: if convoMember(get(/databases/$(database)/documents/conversations/$(conversationId)).data);

        function convoDoc() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
        }

        function validTextMessage() {
          return !('type' in request.resource.data)
            && !('mediaUrl' in request.resource.data)
            && !('dataUrl' in request.resource.data)
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 4000;
        }

        function validTypedText() {
          return request.resource.data.type == 'text'
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 4000;
        }

        function validCaption() {
          return !('text' in request.resource.data)
            || (request.resource.data.text is string && request.resource.data.text.size() <= 500);
        }

        // Image stored as data URL (base64) in Firestore — no Storage bucket.
        function validImageDataUrl() {
          return request.resource.data.type == 'image'
            && request.resource.data.dataUrl is string
            && request.resource.data.dataUrl.size() > 30
            && request.resource.data.dataUrl.size() <= 950000
            && request.resource.data.dataUrl.matches('^data:image/[^;]+;base64,.+')
            && validCaption();
        }

        allow create: if signedIn()
          && (request.auth.uid in convoDoc().members)
          && request.resource.data.senderId == request.auth.uid
          && (
            validTextMessage()
            || validTypedText()
            || validImageDataUrl()
          );

        allow update: if false;

        // Permanent delete allowed only by sender within 5 minutes of creation.
        allow delete: if signedIn()
          && request.auth.uid == resource.data.senderId
          && resource.data.createdAt is timestamp
          && resource.data.createdAt + duration.value(5, 'minutes') >= request.time
          && request.auth.uid in convoDoc().members;
      }
    }
  }
}

